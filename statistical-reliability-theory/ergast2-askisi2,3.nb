Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"x1_", ",", "x2_", ",", "x3_", ",", "x4_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x1"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "x2"}], ")"}]}]}], ")"}], "*", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x2"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "x3"}], ")"}]}]}], ")"}], "*", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x3"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "x4"}], ")"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CurlyPhi]", "[", 
    RowBox[{"x1_", ",", "x2_", ",", "x3_", ",", "x4_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Expand", "[", 
     RowBox[{"F", "[", 
      RowBox[{"x1", ",", "x2", ",", "x3", ",", "x4"}], "]"}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"x1", "^", "n_"}], "\[Rule]", "x1"}], ",", 
      RowBox[{
       RowBox[{"x2", "^", "n_"}], "\[Rule]", "x2"}], ",", " ", 
      RowBox[{
       RowBox[{"x3", "^", "n_"}], "\[Rule]", "x3"}], ",", 
      RowBox[{
       RowBox[{"x4", "^", "n_"}], "\[Rule]", "x4"}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R", "[", "t_", "]"}], "=", 
  RowBox[{"\[CurlyPhi]", "[", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", "t"}], "]"}], ",", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", "t"}], "]"}], ",", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", "t"}], "]"}], ",", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", "t"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]", "[", "t_", "]"}], "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Log", "[", 
       RowBox[{"R", "[", "t", "]"}], "]"}]}], ",", "t"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "t_", "]"}], "=", 
    RowBox[{"-", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"R", "[", "t", "]"}], ",", "t"}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.5947887519931364`*^9, 3.5947890258979363`*^9}, {
  3.5947890747883368`*^9, 3.5947891540689993`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", "2"}], " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "3"}], " ", "t"}]]}], "+", 
  RowBox[{"3", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "2"}], " ", "t"}]]}]}]], "Output",
 CellChangeTimes->{3.5947937041330175`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"N", "[", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"R", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"\[Lambda]", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "3"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"dens", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"f", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "3"}], "}"}]}], "]"}]}]}], "Input",
